{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://emailaiguy.com/schemas/folder-snapshot.schema.json",
  "title": "Email Swipe folder snapshot",
  "type": "object",
  "required": ["folders"],
  "properties": {
    "folderPreference": {
      "type": "string",
      "enum": ["minimal", "moderate", "many"]
    },
    "folders": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "emails"],
        "properties": {
          "name": { "type": "string" },
          "role": {
            "type": "string",
            "enum": ["keep", "important", "dont_keep", "file"]
          },
          "emails": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string" },
                "from": { "type": "string" },
                "sender": { "type": "string" },
                "subject": { "type": "string" },
                "snippet": { "type": "string" },
                "date": { "type": "string" }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
