{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://emailaiguy.com/schemas/accounts.schema.json",
  "title": "Email Swipe unified inbox accounts",
  "type": "object",
  "properties": {
    "enabled": { "type": "boolean", "default": false },
    "defaultAccountId": { "type": ["string", "null"] },
    "accounts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]{0,62}$",
            "description": "Stable slug, e.g. work-gmail"
          },
          "label": { "type": "string", "minLength": 1 },
          "provider": {
            "type": "string",
            "enum": ["gmail", "outlook", "icloud", "imap", "fastmail", "exchange", "other"]
          },
          "role": {
            "type": "string",
            "enum": ["work", "personal", "side_project", "other"]
          },
          "address": { "type": "string" },
          "connectorHint": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
